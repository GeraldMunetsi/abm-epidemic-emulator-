# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/

# ── Python cache ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Large binary data & model files ───────────────────────────
# These are regenerated by running the pipeline — do not commit
*.pkl
*.pt
*.npy
*.dll

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS artefacts ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Jupyter checkpoints ───────────────────────────────────────
.ipynb_checkpoints/

# ── Torch install artefacts ───────────────────────────────────
torch/

# ── Large simulation data CSVs sitting in notebooks scratch folder ──
notebooks/*.csv
notebooks/*.pkl
